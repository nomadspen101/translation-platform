# Copy this file to .env and fill in values.
# Never commit .env to git.

# PostgreSQL connection string
# Development: use the Docker container (see README)
# Production: use the AWS RDS endpoint
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/translation_dev"

# AWS — S3, SES, Textract, Bedrock, SQS
# Development: use the translation-platform-app IAM user credentials
# Production: use an IAM role on App Runner (no static keys)
AWS_REGION="ap-southeast-2"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
S3_BUCKET_NAME="translation-platform-docs"
